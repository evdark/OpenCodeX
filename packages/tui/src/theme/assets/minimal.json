{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkBg": "#0d0d0d",
    "darkPanel": "#141414",
    "darkElement": "#1c1c1c",
    "darkBorder": "#2a2a2a",
    "darkMuted": "#888888",
    "darkText": "#f0f0f0",
    "darkPrimary": "#cccccc",
    "darkSecondary": "#aaaaaa",
    "darkAccent": "#ffffff",
    "darkRed": "#ff5555",
    "darkOrange": "#ffb86c",
    "darkGreen": "#50fa7b",
    "darkCyan": "#8be9fd",
    "darkYellow": "#f1fa8c",
    "lightBg": "#ffffff",
    "lightPanel": "#f7f7f7",
    "lightElement": "#efefef",
    "lightBorder": "#dddddd",
    "lightMuted": "#777777",
    "lightText": "#111111",
    "lightPrimary": "#222222",
    "lightSecondary": "#444444",
    "lightAccent": "#000000",
    "lightRed": "#c0392b",
    "lightOrange": "#d35400",
    "lightGreen": "#1e8449",
    "lightCyan": "#1a5276",
    "lightYellow": "#9a7d0a"
  },
  "theme": {
    "primary": { "dark": "darkPrimary", "light": "lightPrimary" },
    "secondary": { "dark": "darkSecondary", "light": "lightSecondary" },
    "accent": { "dark": "darkAccent", "light": "lightAccent" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkOrange", "light": "lightOrange" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkCyan", "light": "lightCyan" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkPanel", "light": "lightPanel" },
    "backgroundElement": { "dark": "darkElement", "light": "lightElement" },
    "backgroundMenu": { "dark": "darkPanel", "light": "lightPanel" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "darkPrimary", "light": "lightPrimary" },
    "borderSubtle": { "dark": "darkBorder", "light": "lightBorder" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkSecondary", "light": "lightSecondary" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#142018", "light": "#e8f8ef" },
    "diffRemovedBg": { "dark": "#241416", "light": "#fdecea" },
    "diffContextBg": { "dark": "darkPanel", "light": "lightPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#101810", "light": "#d5f0e0" },
    "diffRemovedLineNumberBg": { "dark": "#1c1012", "light": "#f8d7d4" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "darkText", "light": "lightText" },
    "markdownLink": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownLinkText": { "dark": "darkSecondary", "light": "lightSecondary" },
    "markdownCode": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "darkText", "light": "lightText" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "darkPrimary", "light": "lightPrimary" },
    "markdownListEnumeration": { "dark": "darkSecondary", "light": "lightSecondary" },
    "markdownImage": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownImageText": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkSecondary", "light": "lightSecondary" },
    "syntaxFunction": { "dark": "darkPrimary", "light": "lightPrimary" },
    "syntaxVariable": { "dark": "darkText", "light": "lightText" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkOrange", "light": "lightOrange" },
    "syntaxType": { "dark": "darkAccent", "light": "lightAccent" },
    "syntaxOperator": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxPunctuation": { "dark": "darkMuted", "light": "lightMuted" },
    "selectedListItemText": { "dark": "darkBg", "light": "lightBg" }
  }
}
